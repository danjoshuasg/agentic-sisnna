# Plantilla de entorno. Copiar a `.env` y rellenar. NUNCA poner valores reales aquí.
ANTHROPIC_API_KEY=sk-ant-...
INSFORGE_API_KEY=ik_...
VAULT_KEY=            # generar: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"

EMBED_MODEL=intfloat/multilingual-e5-large
LLM_MODEL=claude-sonnet-4-6     # demo: claude-opus-4-8
INSFORGE_PROJECT_ID=fec6df42

DATABASE_URL=                   # postgresql://user:pass@host:5432/db  (de insforge link o Postgres local)
